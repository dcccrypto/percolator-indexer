# ── Network (required) ───────────────────────────────────────
# Which Solana network to index. Must be: devnet | testnet | mainnet
NETWORK=devnet

# Percolator program ID on the target network (required)
PROGRAM_ID=

# Additional program IDs to scan (comma-separated, optional)
# ALL_PROGRAM_IDS=

# Set to "1" to allow mainnet operations (safety guard, required when NETWORK=mainnet)
# FORCE_MAINNET=

# ── Solana RPC (required in production) ──────────────────────
RPC_URL=https://api.devnet.solana.com

# Fallback RPC endpoint (optional)
# FALLBACK_RPC_URL=

# ── Database (required in production) ────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Helius ───────────────────────────────────────────────────
# Generic Helius API key (optional — prefer network-specific keys below)
HELIUS_API_KEY=

# Network-specific Helius API keys (optional, override HELIUS_API_KEY)
# HELIUS_DEVNET_API_KEY=
# HELIUS_MAINNET_API_KEY=

# Webhook HMAC secret for verifying Helius payloads (required in production)
HELIUS_WEBHOOK_SECRET=

# Public URL where Helius sends webhook events (required for webhook registration)
# WEBHOOK_URL=

# ── Server ───────────────────────────────────────────────────
# NODE_ENV: development | production | test (default: development)
# NODE_ENV=development

# Port for the indexer HTTP server (default: 3002)
# INDEXER_PORT=3002

# ── Monitoring (optional) ────────────────────────────────────
# Sentry DSN for error tracking
# SENTRY_DSN=

# Discord webhook URL for operational alerts
# DISCORD_ALERT_WEBHOOK=
